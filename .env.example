# Copy to .env and fill in both values from https://retroachievements.org/controlpanel.php
#
# RA_USERNAME = your LOGIN username (the name you sign in with)
# RA_API_KEY  = Settings → Keys → "Web API Key" (click to copy)
#               NOT a connect token or developer app secret
RA_USERNAME=your_login_username
RA_API_KEY=your_web_api_key_here
