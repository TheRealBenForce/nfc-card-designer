{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowZaparooUploaderListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::zaparoo.therealbenforce.com"
    },
    {
      "Sid": "AllowZaparooUploaderObjectReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::zaparoo.therealbenforce.com/*"
    },
    {
      "Sid": "AllowZaparooUploaderCreateInvalidation",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation"
      ],
      "Resource": "arn:aws:cloudfront::587741272642:distribution/E3MZI2O6LX5XOW"
    }
  ]
}
